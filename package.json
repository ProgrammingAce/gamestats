{
  "name": "gamestats",
  "version": "1.0.0",
  "description": "Auto-detect installed games, measure disk usage, rank by size",
  "type": "module",
  "main": "server/index.js",
  "bin": {
    "gamestats": "./bin/gamestats.js"
  },
  "scripts": {
